# ===== Small-scale evaluation block: No attack / Random / Greedy / Genetic / PGD =====

import random
import string
import numpy as np
import pandas as pd
import torch
from PIL import Image
from transformers import CLIPProcessor, CLIPModel

# ----------------------------
# 0) basic checks
# ----------------------------
assert 'pipe' in globals(), "pipe is not loaded."
assert 'tokenizer' in globals(), "tokenizer is not loaded."
assert 'text_encoder' in globals(), "text_encoder is not loaded."
assert 'char_table' in globals(), "char_table is not loaded."
assert 'search_min_sentence_iteration' in globals(), "search_min_sentence_iteration is not loaded."
assert 'genetic' in globals(), "genetic is not loaded."
assert 'train' in globals(), "train is not loaded."

device = "cuda" if torch.cuda.is_available() else "cpu"
len_prompt = 5

# ----------------------------
# 1) evaluation prompts
# ----------------------------
eval_prompts = [
    "a snake and a young man",
    "a red apple on a plate",
    "a white swan on a lake",
    "a black bicycle against a brick wall",
]

# ----------------------------
# 2) CLIP score model
# ----------------------------
clip_score_model = CLIPModel.from_pretrained("openai/clip-vit-large-patch14").to(device)
clip_score_processor = CLIPProcessor.from_pretrained("openai/clip-vit-large-patch14")

@torch.no_grad()
def compute_clip_score(images, text):
    """
    Return mean cosine similarity between image embeddings and text embedding.
    """
    inputs = clip_score_processor(
        text=[text] * len(images),
        images=images,
        return_tensors="pt",
        padding=True
    ).to(device)

    outputs = clip_score_model(**inputs)
    image_embeds = outputs.image_embeds
    text_embeds = outputs.text_embeds

    image_embeds = image_embeds / image_embeds.norm(dim=-1, keepdim=True)
    text_embeds = text_embeds / text_embeds.norm(dim=-1, keepdim=True)

    scores = (image_embeds * text_embeds).sum(dim=-1)
    return scores.mean().item()

# ----------------------------
# 3) helper functions
# ----------------------------
def random_suffix(char_table, k=5):
    chars = list(char_table)
    return "".join(random.choice(chars) for _ in range(k))

def get_greedy_suffix(sentence):
    adv = search_min_sentence_iteration(
        sentence, char_table, len_prompt, 1,
        tokenizer=tokenizer, text_encoder=text_encoder
    )
    # some utils return full sentence, some may return suffix-like string
    if isinstance(adv, str):
        if adv.startswith(sentence):
            return adv[len(sentence):].strip()
        return adv.strip()
    return str(adv).strip()

def get_genetic_suffix(sentence):
    adv = genetic(
        sentence, char_table, len_prompt,
        tokenizer=tokenizer, text_encoder=text_encoder
    )
    # notebook showed adv[0][0]
    if isinstance(adv, (list, tuple)):
        try:
            return str(adv[0][0]).strip()
        except Exception:
            return str(adv[0]).strip()
    return str(adv).strip()

def get_pgd_suffix(sentence):
    # based on your notebook usage
    max_tensor, loss_list, pgd_prompt, max_loss = train(
        init_per_sample=1,
        sentence=sentence,
        len_prompt=len_prompt,
        char_list=char_table,
        model=text_encoder.text_model,
        iter_num=100,
        eta_u=1,
        tokenizer=tokenizer,
        text_encoder=text_encoder,
    )
    if isinstance(pgd_prompt, str):
        return pgd_prompt.strip()
    if isinstance(pgd_prompt, (list, tuple)):
        return str(pgd_prompt[0]).strip()
    return str(pgd_prompt).strip()

def build_prompt(base_sentence, method):
    if method == "no_attack":
        return base_sentence, ""
    elif method == "random":
        sfx = random_suffix(char_table, len_prompt)
    elif method == "greedy":
        sfx = get_greedy_suffix(base_sentence)
    elif method == "genetic":
        sfx = get_genetic_suffix(base_sentence)
    elif method == "pgd":
        sfx = get_pgd_suffix(base_sentence)
    else:
        raise ValueError(f"Unknown method: {method}")

    full_prompt = f"{base_sentence} {sfx}".strip()
    return full_prompt, sfx

def generate_images(prompt, n_images=3, seed=27, steps=50):
    generator = torch.Generator(device=device).manual_seed(seed)
    prompt_list = [prompt] * n_images

    if device == "cuda":
        with torch.autocast("cuda"):
            images = pipe(prompt_list, generator=generator, num_inference_steps=steps).images
    else:
        images = pipe(prompt_list, generator=generator, num_inference_steps=steps).images
    return images

# ----------------------------
# 4) run small-scale evaluation
# ----------------------------
methods = ["no_attack", "random", "greedy", "genetic", "pgd"]
records = []

for base_sentence in eval_prompts:
    print(f"\n=== Base prompt: {base_sentence} ===")
    for method in methods:
        try:
            attacked_prompt, suffix = build_prompt(base_sentence, method)
            images = generate_images(attacked_prompt, n_images=3, seed=27, steps=50)

            # paper's untargeted setting compares original sentence vs generated images
            score = compute_clip_score(images, base_sentence)

            print(f"[{method}] suffix={repr(suffix)} | score={score:.4f}")
            records.append({
                "base_prompt": base_sentence,
                "method": method,
                "suffix": suffix,
                "used_prompt": attacked_prompt,
                "clip_score_vs_original": score
            })
        except Exception as e:
            print(f"[{method}] failed: {e}")
            records.append({
                "base_prompt": base_sentence,
                "method": method,
                "suffix": "ERROR",
                "used_prompt": "ERROR",
                "clip_score_vs_original": np.nan
            })

# ----------------------------
# 5) summarize results
# ----------------------------
df = pd.DataFrame(records)
summary = df.pivot_table(
    index="base_prompt",
    columns="method",
    values="clip_score_vs_original",
    aggfunc="mean"
)

summary.loc["OVERALL_MEAN"] = summary.mean(axis=0, numeric_only=True)

print("\n===== Detailed records =====")
display(df)

print("\n===== Summary table =====")
display(summary)

# optional: save
df.to_csv("qf_attack_small_eval_records.csv", index=False)
summary.to_csv("qf_attack_small_eval_summary.csv")

print("\nSaved:")
print("- qf_attack_small_eval_records.csv")
print("- qf_attack_small_eval_summary.csv")

